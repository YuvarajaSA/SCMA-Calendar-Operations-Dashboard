# .streamlit/secrets.toml
# ──────────────────────────────────────────────────────────────
#  Copy this file → secrets.toml, fill in your values.
#  NEVER commit secrets.toml to git.
# ──────────────────────────────────────────────────────────────

[supabase]
url          = "https://YOUR_PROJECT_ID.supabase.co"
anon_key     = "YOUR_ANON_PUBLIC_KEY"
redirect_url = "http://localhost:8501"   # Change to your deployed URL for production
